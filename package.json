{
  "name": "claude-command-center",
  "version": "1.0.0",
  "description": "Dashboard for visualizing and managing your Claude Code ecosystem",
  "license": "MIT",
  "type": "module",
  "bin": {
    "claude-command-center": "dist/index.cjs"
  },
  "files": [
